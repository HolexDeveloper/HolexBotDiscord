# ============================================================
# Discord Bot Credentials (REQUIRED)
# ============================================================
# Obtain from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# ============================================================
# Operational Knobs (OPTIONAL - all have sane defaults)
# ============================================================
# Log level: debug | info | warn | error
LOG_LEVEL=info

# Cache TTL in milliseconds (default: 300000 = 5 minutes)
CACHE_TTL_MS=300000

# Network timeout per fetch attempt in milliseconds (default: 5000)
FETCH_TIMEOUT_MS=5000

# Maximum retries on retryable failures (default: 3)
FETCH_MAX_RETRIES=3

# Base backoff delay in milliseconds (default: 1000; sequence: 1s, 2s, 4s)
FETCH_BASE_BACKOFF_MS=1000

# Rate limit window in milliseconds (default: 15000 = 15 seconds)
RATE_LIMIT_WINDOW_MS=15000

# Rate limit max invocations per window per user (default: 1)
RATE_LIMIT_MAX=1
